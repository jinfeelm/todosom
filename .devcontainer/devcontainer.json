{
  "name": "TodoSom",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "npm ci",
  "forwardPorts": [8081, 19000, 19006],
  "portsAttributes": {
    "8081": { "label": "Expo Metro", "onAutoForward": "notify" },
    "19006": { "label": "Expo Web", "onAutoForward": "openBrowser" }
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "expo.vscode-expo-tools"]
    }
  },
  "remoteUser": "node"
}
